# LearnX-Delftse secrets — copy to `.env` and fill in. `.env` is gitignored.
# This makes the app independent of LearnX-Radar: its own keys, its own bot config.
# In the GitHub Action these same names come from repo secrets instead of this file.

# --- LLM (only needed to (re)generate chapters with build/convert.py) -------------
# NVIDIA NIM is the primary provider (OpenAI-compatible, free tier). Required for
# regeneration; NOT needed just to run the trainer or the Telegram sync.
NVIDIA_API_KEY=

# Optional Groq fallback — if set, used when NVIDIA times out. Leave blank to skip.
GROQ_API_KEY=

# --- Telegram (needed for the personalization loop / sync runner) -----------------
# You may reuse Radar's bot — same token here. Get it from @BotFather.
TELEGRAM_BOT_TOKEN=
# The bot's @username WITHOUT the @ (used to build the t.me deep links in the page).
# Reusing Radar's bot? Use the same value you generated the chapters with.
TELEGRAM_BOT_USERNAME=Prakly_notification_bot
# Your own numeric chat id — sync only accepts recall/review taps from this chat.
TELEGRAM_CHAT_ID=

# --- Personalization token --------------------------------------------------------
# Any long random string. It HMACs your chat id into the review/progress filenames
# (review/<token>.json) so they aren't enumerable. Can differ from Radar's — this is
# a separate app with separate published files. Keep it stable once you pick one.
REVIEW_TOKEN_SECRET=

# --- Audio publishing (optional) --------------------------------------------------
# Fallback base URL for a chapter's mp3 (audio_url) when the same-origin copy isn't
# found. The trainer serves delftse-<n>.mp3 same-origin first, so this is only a
# fallback (e.g. a GitHub Releases base). Leave blank for local/dev.
AUDIO_BASE=